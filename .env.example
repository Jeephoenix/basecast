# ─── Wallet ────────────────────────────────────────────────────────────────────
# Your deployer wallet private key (WITHOUT 0x prefix is fine too)
PRIVATE_KEY=your_private_key_here

# ─── RPC Endpoints (CDP) ───────────────────────────────────────────────────────
# Get your CDP API key at: https://portal.cdp.coinbase.com
# Replace YOUR_CDP_API_KEY below with your actual key
BASE_MAINNET_RPC=https://api.developer.coinbase.com/rpc/v1/base/YOUR_CDP_API_KEY
BASE_SEPOLIA_RPC=https://api.developer.coinbase.com/rpc/v1/base-sepolia/YOUR_CDP_API_KEY

# ─── Chainlink VRF ─────────────────────────────────────────────────────────────
# Create subscription at: https://vrf.chain.link (select Base network)
# Fund it with LINK tokens, then paste the subscription ID here
VRF_SUBSCRIPTION_ID=your_subscription_id_here

# ─── USDC Addresses ────────────────────────────────────────────────────────────
# Base Mainnet USDC (official Circle contract)
USDC_BASE_MAINNET=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# Base Sepolia USDC (testnet mock — deploy your own or use faucet)
USDC_BASE_SEPOLIA=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# ─── Frontend (Next.js) ────────────────────────────────────────────────────────
# After deployment, paste contract addresses here for the frontend
NEXT_PUBLIC_GAME_VAULT_ADDRESS=
NEXT_PUBLIC_COINFLIP_ADDRESS=
NEXT_PUBLIC_DICEROLL_ADDRESS=
NEXT_PUBLIC_USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
NEXT_PUBLIC_CHAIN_ID=8453

# ─── Optional ──────────────────────────────────────────────────────────────────
REPORT_GAS=false
